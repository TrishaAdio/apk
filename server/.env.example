# Copy this file to .env and adjust as needed.

# Port the API listens on (your VPS runs the monitor on 5000)
PORT=5000

# Shared secret. The Android app must send this in the "X-Api-Key" header.
# Change this to a long random string before real use.
API_KEY=change-me-to-a-long-random-secret

# IANA timezone used to decide what "today" means for the stats endpoints.
TZ=Asia/Kolkata
